graph TD
    classDef orchestrator fill:#0f172a,stroke:#38bdf8,stroke-width:2px,color:#fff;
    classDef responder fill:#0f172a,stroke:#818cf8,stroke-width:2px,color:#fff;
    classDef human fill:#0f172a,stroke:#f59e0b,stroke-width:2px,color:#fff;

    A([Human / Voice Input]):::human -->|HTTP POST| B[FastAPI Backend]:::orchestrator
    B -->|Initialize| C[Orchestrator Agent]:::orchestrator
    
    C -->|to_ambulance| D[Ambulance Agent]:::responder
    C -->|to_fire| E[Fire Agent]:::responder
    C -->|to_police| F[Police Agent]:::responder
    C -->|to_hospital| G[Hospital Agent]:::responder
    C -->|to_instruction| H[Instruction Agent]:::responder

    D --> I[(Shared State)]:::orchestrator
    E --> I
    F --> I
    G --> I
    H --> I

    I -->|JSON / SSE| J([Live Simulation UI]):::human

